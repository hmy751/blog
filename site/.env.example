# Canonical URL for production SEO output.
# NEXT_PUBLIC_SITE_URL=https://example.com

# Optional reader analytics. Leave unset for local/off builds.
# NEXT_PUBLIC_READER_ANALYTICS_PROVIDER=clarity
# NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Local-only Microsoft Clarity Data Export API token.
# Never expose this as NEXT_PUBLIC_*.
# CLARITY_API_TOKEN=
# CLARITY_EXPORT_NUM_DAYS=1
# CLARITY_EXPORT_QUERIES=url,device-url
